{
  "name": "bitburner-scripts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "viteburner",
    "lint": "npm run lint:ts && npm run lint:eslint && npm run lint:prettier",
    "lint:ts": "tsc --noEmit",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check \"**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,json}\"",
    "format": "prettier --write \"**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,json}\""
  },
  "author": "Balour",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "viteburner": "file:../viteburner"
  },
  "license": "MIT"
